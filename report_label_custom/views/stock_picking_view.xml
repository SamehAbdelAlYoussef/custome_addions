<odoo>
    <data>

        <record id="print_label_button_stock" model="ir.ui.view">
            <field name="name">print.label.button.stock</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button class="oe_stat_button" type="object" name="print_labels" icon="fa-print" string="Custom Print Labels"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>