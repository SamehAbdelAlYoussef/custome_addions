<odoo>
    <data>

        <record id="print_label_button_product" model="ir.ui.view">
            <field name="name">print.label.button.product</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button class="oe_stat_button" type="object" name="print_labels" icon="fa-print" string="Custom Print Labels"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>