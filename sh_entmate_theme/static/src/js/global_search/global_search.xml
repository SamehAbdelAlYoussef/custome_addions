<?xml version="1.0" encoding="UTF-8"?>

<templates id="template" xml:space="preserve">

	<t t-name="sh_entmate_theme.GlobalSearch">
    	<t t-if="sh_enable_gloabl_search_mode">
        <div class="sh_global_search" style="display:none;">
            <div class="sh_search_container form-row align-items-center">
                <div class="sh_search_input">
                    <div class="input-group">
                        <input type="text" placeholder="Search ..."
                               t-att-class="'form-control ' + (state.isExpanded ? 'usermenu_search_input2' : 'usermenu_search_input')"
                               t-on-keypress="_searchData"
                               t-on-keyup="onKeyUp"
                               t-model="state.query"
                               aria-label="Search input" id="global_search_input" />
                        <div class="input-group-prepend">
                            <div class="input-group-text">
                                <span class="icon-search fa fa-search" t-on-click="_searchData"></span>
                            </div>
                        </div>
                    </div>
                </div>
				<div class="sh_search_results col-md-10 ml-auto mr-auto" t-if="state.query">
				<t t-if="state.hasResults">
					<t t-foreach="state.results" t-as="result" t-key="result.id">
                        <t t-log="result.href"/>
						<a t-attf-class="dropdown-item col-12 ml-auto mr-auto"
						   target="_blank"
						   t-attf-href="#{result.href}">
						   <t t-esc="result.name"/>
						</a>
					</t>
				</t>
				<t t-else="">
					<p>No results found</p>
				</t>
			</div>
            </div>
        </div>
    </t>
</t>

</templates>
