<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Managed DB Form ──────────────────────────── -->
    <record id="view_ms_managed_db_form" model="ir.ui.view">
        <field name="name">ms.managed.db.form</field>
        <field name="model">ms.managed.db</field>
        <field name="arch" type="xml">
            <form string="Managed Database">
                <header>
                    <button name="action_open_as_admin" string="🔗 Open as Admin"
                            type="object" class="btn-primary"
                            invisible="state != 'ready'"/>
                    <button name="action_impersonate_admin" string="🔑 Get Login Info"
                            type="object" class="btn-info"/>
                    <button name="action_retry_provision" string="🔄 Retry Provision"
                            type="object"
                            invisible="state != 'error'"/>
                    <button name="action_suspend" string="Suspend"
                            type="object"
                            invisible="state != 'ready'"/>
                    <button name="action_unsuspend" string="Reactivate"
                            type="object"
                            invisible="state != 'suspended'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="provisioning,ready,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Database Info">
                            <field name="subdomain"/>
                            <field name="url" widget="url" readonly="1"/>
                            <field name="subscription_id"/>
                            <field name="template_id"/>
                        </group>
                        <group string="Admin Credentials">
                            <field name="admin_email"/>
                            <field name="admin_password" password="True"/>
                        </group>
                    </group>
                    <group string="Modules Installed">
                        <field name="modules_installed" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Error Details" invisible="state != 'error'">
                        <field name="error_message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ms_managed_db_list" model="ir.ui.view">
        <field name="name">ms.managed.db.list</field>
        <field name="model">ms.managed.db</field>
        <field name="arch" type="xml">
            <list string="Managed Databases"
                  decoration-success="state == 'ready'"
                  decoration-danger="state == 'error'"
                  decoration-warning="state == 'provisioning'"
                  decoration-muted="state in ('suspended','deleted')">
                <field name="name"/>
                <field name="subdomain"/>
                <field name="url" widget="url"/>
                <field name="subscription_id"/>
                <field name="template_id"/>
                <field name="admin_email"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'ready'"
                       decoration-danger="state == 'error'"
                       decoration-warning="state == 'provisioning'"/>
                <button name="action_open_as_admin" type="object"
                        string="Open" icon="fa-external-link"
                        invisible="state != 'ready'"/>
            </list>
        </field>
    </record>

    <record id="action_ms_managed_db" model="ir.actions.act_window">
        <field name="name">Customer Databases</field>
        <field name="res_model">ms.managed.db</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
