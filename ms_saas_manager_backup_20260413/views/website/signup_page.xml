<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ── Signup Page ─────────────────────────────── -->
<template id="page_signup" name="Signup Page">
  <t t-call="website.layout">
    <div id="wrap" style="background:#f8f9fa;min-height:100vh;padding:60px 20px;">
      <div style="max-width:520px;margin:0 auto;background:#fff;border-radius:12px;
                  padding:40px;box-shadow:0 4px 20px rgba(0,0,0,0.1);">

        <!-- Plan badge -->
        <div style="text-align:center;margin-bottom:24px;">
          <span style="background:#1A6B3A;color:#fff;padding:6px 20px;border-radius:20px;font-size:14px;">
            <t t-esc="plan.name"/> Plan
          </span>
          <t t-if="billing == 'yearly'">
            <span style="background:#27ae60;color:#fff;padding:6px 14px;border-radius:20px;
                         font-size:13px;margin-left:8px;">Yearly</span>
          </t>
        </div>

        <h2 style="text-align:center;color:#1A6B3A;margin-bottom:28px;">
          Start Your 7-Day Free Trial
        </h2>

        <!-- Errors -->
        <t t-if="errors">
          <div style="background:#fdecea;border-left:4px solid #e74c3c;padding:12px;margin-bottom:20px;border-radius:4px;">
            <t t-foreach="errors.values()" t-as="err">
              <p style="margin:4px 0;color:#c0392b;font-size:14px;"><t t-esc="err"/></p>
            </t>
          </div>
        </t>

        <form action="/signup/submit" method="post">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <input type="hidden" name="plan_code" t-att-value="plan.code"/>
          <input type="hidden" name="billing" t-att-value="billing"/>

          <div style="margin-bottom:16px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;color:#333;">Full Name *</label>
            <input name="name" type="text" required="1"
                   t-att-value="post.get('name', '') if post else ''"
                   style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;
                          font-size:15px;box-sizing:border-box;" placeholder="Ahmed Mohamed"/>
          </div>

          <div style="margin-bottom:16px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;color:#333;">Email Address *</label>
            <input name="email" type="email" required="1"
                   t-att-value="post.get('email', '') if post else ''"
                   style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;
                          font-size:15px;box-sizing:border-box;" placeholder="ahmed@company.com"/>
          </div>

          <div style="margin-bottom:16px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;color:#333;">Phone *</label>
            <input name="phone" type="tel" required="1"
                   t-att-value="post.get('phone', '') if post else ''"
                   style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;
                          font-size:15px;box-sizing:border-box;" placeholder="+20 10 xxxx xxxx"/>
          </div>

          <div style="margin-bottom:16px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;color:#333;">Company Name *</label>
            <input name="company" type="text" required="1"
                   t-att-value="post.get('company', '') if post else ''"
                   style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;
                          font-size:15px;box-sizing:border-box;" placeholder="Your Company LLC"/>
          </div>

          <!-- Subdomain Field -->
          <div style="margin-bottom:24px;">
            <label style="display:block;font-weight:600;margin-bottom:6px;color:#333;">Choose Your Subdomain *</label>
            <div style="display:flex;align-items:center;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
              <input name="subdomain" type="text" required="1"
                     t-att-value="post.get('subdomain', '') if post else ''"
                     style="flex:1;padding:10px 14px;border:none;font-size:15px;box-sizing:border-box;outline:none;"
                     placeholder="yourcompany"
                     pattern="[a-z0-9\-]+"
                     title="Only lowercase letters, numbers, and hyphens"/>
              <span style="background:#f0f4f8;padding:10px 14px;color:#1A6B3A;font-size:14px;font-weight:600;white-space:nowrap;border-left:1px solid #ddd;">
                .msolutions-eg.com
              </span>
            </div>
            <p id="ms-subdomain-status" style="margin:6px 0 0;font-size:12px;color:#888;">
              Lowercase letters, numbers, and hyphens only
            </p>
          </div>

          <button type="submit"
                  style="width:100%;background:#1A6B3A;color:#fff;padding:14px;border:none;
                         border-radius:8px;font-size:16px;font-weight:bold;cursor:pointer;">
            Start Free Trial Now
          </button>
        </form>

        <p style="text-align:center;margin-top:16px;font-size:13px;color:#aaa;">
          No credit card required · Cancel anytime
        </p>

        <p style="text-align:center;margin-top:8px;font-size:13px;">
          <a href="/pricing" style="color:#1A6B3A;">← Back to Pricing</a>
        </p>

        <!-- Loading Overlay -->
        <div id="ms-loading" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
                    background:rgba(255,255,255,0.95);z-index:9999;
                    justify-content:center;align-items:center;flex-direction:column;">
          <div style="text-align:center;">
            <div style="width:60px;height:60px;border:4px solid #e0e0e0;border-top:4px solid #1A6B3A;
                        border-radius:50%;margin:0 auto 24px;" id="ms-spinner"></div>
            <h3 style="color:#1A6B3A;margin:0 0 12px;font-size:22px;">Setting up your system...</h3>
            <p style="color:#666;font-size:15px;margin:0 0 8px;">Creating your private cloud database</p>
            <p style="color:#888;font-size:13px;margin:0;">This may take 2–3 minutes. Please don't close this page.</p>
          </div>
        </div>

      </div>
    </div>
  </t>
</template>

<!-- ── Thank You Page ──────────────────────────── -->
<template id="page_thank_you" name="Thank You Page">
  <t t-call="website.layout">
    <div id="wrap" style="background:#f8f9fa;min-height:100vh;padding:80px 20px;">
      <div style="max-width:560px;margin:0 auto;text-align:center;">

        <div style="font-size:72px;margin-bottom:20px;">🎉</div>
        <h1 style="color:#1A6B3A;font-size:36px;margin-bottom:12px;">You're all set!</h1>
        <p style="color:#555;font-size:18px;margin-bottom:32px;">
          Your free trial has started. Your system is being prepared and will be
          ready in <strong>3–5 minutes</strong>.
        </p>

        <t t-if="subscription">
          <div style="background:#fff;border-radius:12px;padding:30px;
                      box-shadow:0 4px 20px rgba(0,0,0,0.08);margin-bottom:32px;text-align:left;">
            <h3 style="color:#1A6B3A;margin-top:0;">Your Details</h3>
            <table style="width:100%;border-collapse:collapse;">
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid #eee;color:#888;">Subscription</td>
                <td style="padding:10px 0;border-bottom:1px solid #eee;font-weight:600;">
                  <t t-esc="subscription.name"/>
                </td>
              </tr>
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid #eee;color:#888;">Plan</td>
                <td style="padding:10px 0;border-bottom:1px solid #eee;font-weight:600;">
                  <t t-esc="subscription.template_id.name"/>
                </td>
              </tr>
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid #eee;color:#888;">Trial Ends</td>
                <td style="padding:10px 0;border-bottom:1px solid #eee;font-weight:600;">
                  <t t-esc="subscription.trial_end"/>
                </td>
              </tr>
              <t t-if="subscription.url">
                <tr>
                  <td style="padding:10px 0;color:#888;">Your URL</td>
                  <td style="padding:10px 0;font-weight:600;">
                    <a t-att-href="subscription.url" style="color:#1A6B3A;">
                      <t t-esc="subscription.url"/>
                    </a>
                  </td>
                </tr>
              </t>
            </table>
          </div>
        </t>

        <p style="color:#555;margin-bottom:24px;">
          Check your email for login credentials and getting-started tips.
        </p>

        <a href="/"
           style="background:#1A6B3A;color:#fff;padding:14px 32px;border-radius:8px;
                  text-decoration:none;font-size:16px;font-weight:bold;">
          Return to Homepage
        </a>

      </div>
    </div>
  </t>
</template>

</data>
</odoo>
