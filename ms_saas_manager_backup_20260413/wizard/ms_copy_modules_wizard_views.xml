<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ms_copy_modules_wizard_form" model="ir.ui.view">
        <field name="name">ms.copy.modules.wizard.form</field>
        <field name="model">ms.copy.modules.wizard</field>
        <field name="arch" type="xml">
            <form string="Copy Modules From Another Plan">
                <group>
                    <field name="target_template_id" readonly="1"/>
                    <field name="source_template_id"/>
                    <field name="replace_existing"/>
                </group>
                <footer>
                    <button name="action_copy" type="object" string="Copy Modules" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
