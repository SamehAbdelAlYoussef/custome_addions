<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

<template id="page_pricing" name="Manager Solutions Pricing">
  <t t-call="website.layout">
    <t t-set="title">Pricing — Manager Solutions</t>

    <div id="wrap" style="">

    <!-- ══ HERO ══ -->
    <section style="background:linear-gradient(135deg,#0d2137,#1A6B3A);padding:80px 20px 60px;text-align:center;">
      <div class="container">
        <h1 style="color:#fff;font-size:42px;font-weight:800;margin:0 0 14px;">
          Simple, Transparent Pricing
        </h1>
        <p style="color:#aed6f1;font-size:18px;margin-bottom:30px;">
          Choose the plan that fits your business. Upgrade anytime.
        </p>
        <div id="ms-billing-toggle" style="display:inline-flex;background:rgba(255,255,255,0.1);
                    border-radius:24px;padding:4px;">
          <button class="ms-toggle-btn ms-toggle-active" data-cycle="monthly"
                  style="background:#fff;color:#1A5276;border:none;padding:10px 28px;
                         border-radius:20px;font-size:15px;font-weight:700;cursor:pointer;">
            Monthly
          </button>
          <button class="ms-toggle-btn" data-cycle="yearly"
                  style="background:transparent;color:#fff;border:none;padding:10px 28px;
                         border-radius:20px;font-size:15px;font-weight:700;cursor:pointer;">
            Yearly
            <span style="background:#f39c12;color:#fff;padding:2px 8px;border-radius:10px;
                         font-size:11px;margin-left:6px;">Save ~17%</span>
          </button>
        </div>
      </div>
    </section>

    <!-- ══ PLAN CARDS ══ -->
    <section style="padding:60px 20px 80px;background:#f8fafb;">
      <div class="container">
        <div class="row justify-content-center" style="align-items:stretch;">
          <t t-foreach="plans" t-as="plan">
            <div class="col-lg-3 col-md-6 mb-4 d-flex">
              <div t-att-style="'background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 4px 30px rgba(0,0,0,0.08);width:100%;display:flex;flex-direction:column;border:2px solid ' + ('transparent' if not plan.badge else '#1A6B3A') + ';'">

                <t t-if="plan.badge">
                  <div style="background:#1A6B3A;color:#fff;text-align:center;padding:8px;font-size:13px;font-weight:700;">
                    <t t-esc="plan.badge"/>
                  </div>
                </t>

                <div style="padding:36px 24px;display:flex;flex-direction:column;flex:1;">
                  <div style="text-align:center;margin-bottom:20px;">
                    <div style="width:56px;height:56px;background:#1A6B3A15;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                      <i class="fa fa-cube" style="font-size:24px;color:#1A6B3A;"/>
                    </div>
                    <h3 style="color:#1A5276;font-size:22px;font-weight:800;margin:0;">
                      <t t-esc="plan.name"/>
                    </h3>
                    <p style="color:#888;font-size:14px;margin:6px 0 0;">
                      <t t-esc="plan.description"/>
                    </p>
                  </div>

                  <!-- Price Monthly -->
                  <div class="ms-price-monthly" style="text-align:center;margin-bottom:24px;">
                    <span style="font-size:40px;font-weight:800;color:#1A5276;">
                      <t t-esc="'{:,.0f}'.format(plan.monthly_price)"/>
                    </span>
                    <span style="color:#888;font-size:15px;"> EGP/mo</span>
                  </div>
                  <!-- Price Yearly -->
                  <div class="ms-price-yearly" style="display:none;text-align:center;margin-bottom:24px;">
                    <span style="font-size:40px;font-weight:800;color:#1A5276;">
                      <t t-esc="'{:,.0f}'.format(plan.yearly_price)"/>
                    </span>
                    <span style="color:#888;font-size:15px;"> EGP/yr</span>
                    <t t-if="plan.yearly_saving_pct > 0">
                      <div style="color:#1A6B3A;font-size:13px;font-weight:600;margin-top:4px;">
                        Save <t t-esc="plan.yearly_saving_pct"/>%
                      </div>
                    </t>
                  </div>

                  <!-- Users -->
                  <div style="text-align:center;margin-bottom:20px;padding:10px;background:#f0f7ff;border-radius:8px;">
                    <span style="color:#1A5276;font-weight:600;">
                      <t t-esc="plan.max_users"/> users included
                    </span>
                  </div>

                  <!-- Features -->
                  <ul style="list-style:none;padding:0;margin:0 0 28px;flex:1;">
                    <t t-foreach="(plan.features or '').strip().split('\n')" t-as="feat">
                      <t t-if="feat.strip()">
                        <li style="padding:7px 0;color:#555;font-size:14px;display:flex;align-items:center;gap:10px;">
                          <i class="fa fa-check-circle" style="color:#1A6B3A;font-size:16px;flex-shrink:0;"/>
                          <span t-esc="feat.strip()"/>
                        </li>
                      </t>
                    </t>
                  </ul>

                  <!-- CTA — always at bottom -->
                  <div style="text-align:center;margin-top:auto;">
                    <a class="ms-btn-monthly"
                       t-att-href="'/signup/' + plan.code + '?billing=monthly'"
                       style="display:block;background:#1A6B3A;color:#fff;padding:14px;border-radius:8px;text-decoration:none;font-size:16px;font-weight:700;">
                      Start 7-Day Free Trial
                    </a>
                    <a class="ms-btn-yearly"
                       t-att-href="'/signup/' + plan.code + '?billing=yearly'"
                       style="display:none;background:#1A6B3A;color:#fff;padding:14px;border-radius:8px;text-decoration:none;font-size:16px;font-weight:700;">
                      Start 7-Day Free Trial
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </t>
        </div>
      </div>
    </section>

    <!-- ══ FAQ ══ -->
    <section class="oe_structure" style="padding:60px 20px;background:#fff;">
      <div class="container" style="max-width:700px;margin:0 auto;">
        <h2 style="text-align:center;color:#1A5276;font-size:32px;font-weight:800;margin-bottom:40px;">
          Frequently Asked Questions
        </h2>
        <div style="background:#f8fafb;border-radius:16px;overflow:hidden;">
          <div style="padding:22px 28px;border-bottom:1px solid #eee;">
            <h4 style="color:#1A5276;margin:0 0 8px;font-size:16px;">What happens after the trial?</h4>
            <p style="color:#666;font-size:14px;margin:0;line-height:1.8;">You'll receive an invoice. If you don't subscribe, your account is suspended and data is kept for 30 days.</p>
          </div>
          <div style="padding:22px 28px;border-bottom:1px solid #eee;">
            <h4 style="color:#1A5276;margin:0 0 8px;font-size:16px;">Can I upgrade or downgrade?</h4>
            <p style="color:#666;font-size:14px;margin:0;line-height:1.8;">Yes — upgrade anytime and your data is preserved. Downgrade is possible at renewal.</p>
          </div>
          <div style="padding:22px 28px;">
            <h4 style="color:#1A5276;margin:0 0 8px;font-size:16px;">Does it support Egyptian taxes?</h4>
            <p style="color:#666;font-size:14px;margin:0;line-height:1.8;">Yes. Pre-configured for Egyptian VAT and withholding tax requirements.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ FOOTER ══ -->
</div>
  </t>
</template>

</data>
</odoo>
