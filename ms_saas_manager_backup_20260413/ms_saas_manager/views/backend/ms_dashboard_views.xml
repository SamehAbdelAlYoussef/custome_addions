<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ms_dashboard" model="ir.ui.view">
        <field name="name">ms.saas.dashboard</field>
        <field name="model">ms.subscription</field>
        <field name="arch" type="xml">
            <graph string="Subscriptions by Plan" type="pie">
                <field name="template_id"/>
            </graph>
        </field>
    </record>

    <record id="view_ms_dashboard_pivot" model="ir.ui.view">
        <field name="name">ms.saas.dashboard.pivot</field>
        <field name="model">ms.subscription</field>
        <field name="arch" type="xml">
            <pivot string="Subscription Analysis">
                <field name="template_id" type="row"/>
                <field name="billing_cycle" type="col"/>
                <field name="total_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ms_dashboard" model="ir.actions.act_window">
        <field name="name">SaaS Dashboard</field>
        <field name="res_model">ms.subscription</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="domain">[('state', 'in', ('trial','active'))]</field>
    </record>

</odoo>
