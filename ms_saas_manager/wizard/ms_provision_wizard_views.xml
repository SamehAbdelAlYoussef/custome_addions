<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ms_provision_wizard_form" model="ir.ui.view">
        <field name="name">ms.provision.wizard.form</field>
        <field name="model">ms.provision.wizard</field>
        <field name="arch" type="xml">
            <form string="Provision Customer Database">
                <group>
                    <field name="subscription_id" readonly="1"/>
                    <field name="template_id"/>
                    <field name="db_name"/>
                    <field name="subdomain"/>
                    <field name="admin_email"/>
                    <field name="admin_password"/>
                    <field name="language"/>
                </group>
                <div class="alert alert-warning" role="alert">
                    ⚠️ This will create a new Odoo database and install all plan modules.
                    This process takes <strong>3–5 minutes</strong>.
                </div>
                <footer>
                    <button name="action_provision" string="🚀 Provision Database"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ms_provision_wizard" model="ir.actions.act_window">
        <field name="name">Provision Database</field>
        <field name="res_model">ms.provision.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
