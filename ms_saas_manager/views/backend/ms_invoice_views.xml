<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ms_invoice_form" model="ir.ui.view">
        <field name="name">ms.invoice.form</field>
        <field name="model">ms.invoice</field>
        <field name="arch" type="xml">
            <form string="Invoice">
                <header>
                    <button name="action_send" string="Send to Customer"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_generate_paymob_link" string="💳 Generate Paymob Link"
                            type="object" class="btn-info"
                            invisible="state in ('paid','cancelled')"/>
                    <button name="action_mark_paid" string="✅ Mark Paid"
                            type="object" class="btn-success"
                            invisible="state in ('paid','cancelled')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('paid','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="subscription_id"/>
                            <field name="template_id"/>
                            <field name="billing_cycle"/>
                        </group>
                        <group>
                            <field name="date_invoice"/>
                            <field name="due_date"/>
                            <field name="date_paid"/>
                            <field name="amount" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Paymob">
                        <field name="paymob_order_id" readonly="1"/>
                        <field name="paymob_transaction_id" readonly="1"/>
                        <field name="paymob_payment_url" widget="url" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ms_invoice_list" model="ir.ui.view">
        <field name="name">ms.invoice.list</field>
        <field name="model">ms.invoice</field>
        <field name="arch" type="xml">
            <list string="Invoices"
                  decoration-success="state == 'paid'"
                  decoration-danger="state == 'overdue'"
                  decoration-warning="state == 'sent'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="template_id"/>
                <field name="billing_cycle"/>
                <field name="date_invoice"/>
                <field name="due_date"/>
                <field name="amount"/>
                <field name="date_paid"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-danger="state == 'overdue'"
                       decoration-warning="state == 'sent'"/>
                <button name="action_mark_paid" type="object" string="Mark Paid"
                        icon="fa-check" invisible="state == 'paid'"/>
            </list>
        </field>
    </record>

    <record id="action_ms_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">ms.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_state': 1}</field>
    </record>

</odoo>
