<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── BASIC ─────────────────────────────────── -->
        <record id="plan_basic" model="ms.plan.template">
            <field name="name">Basic</field>
            <field name="name_ar">الأساسية</field>
            <field name="code">basic</field>
            <field name="sequence">1</field>
            <field name="monthly_price">1999</field>
            <field name="yearly_price">19990</field>
            <field name="max_users">5</field>
            <field name="trial_days">14</field>
            <field name="is_featured">False</field>
            <field name="description">For small businesses with an internal accounting team</field>
            <field name="features">Odoo Online System
5 Users Included
Initial Accounting Setup
Chart of Accounts + Taxes
Secure Cloud Hosting
Basic Technical Support</field>
        </record>

        <record id="plan_basic_mod1" model="ms.plan.template.module">
            <field name="template_id" ref="plan_basic"/>
            <field name="sequence">1</field>
            <field name="name">base</field>
            <field name="label">Base</field>
            <field name="category">standard</field>
            <field name="is_required">True</field>
        </record>
        <record id="plan_basic_mod2" model="ms.plan.template.module">
            <field name="template_id" ref="plan_basic"/>
            <field name="sequence">2</field>
            <field name="name">web</field>
            <field name="label">Web Interface</field>
            <field name="category">standard</field>
            <field name="is_required">True</field>
        </record>
        <record id="plan_basic_mod3" model="ms.plan.template.module">
            <field name="template_id" ref="plan_basic"/>
            <field name="sequence">3</field>
            <field name="name">account</field>
            <field name="label">Accounting</field>
            <field name="category">account</field>
            <field name="is_required">True</field>
        </record>
        <record id="plan_basic_mod4" model="ms.plan.template.module">
            <field name="template_id" ref="plan_basic"/>
            <field name="sequence">4</field>
            <field name="name">mail</field>
            <field name="label">Email &amp; Messaging</field>
            <field name="category">standard</field>
            <field name="is_required">True</field>
        </record>

