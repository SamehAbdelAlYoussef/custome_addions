<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_check_trials" model="ir.cron">
            <field name="name">SaaS: Check Expiring Trials</field>
            <field name="model_id" ref="ms_saas_manager.model_ms_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_trials()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="cron_auto_renew" model="ir.cron">
            <field name="name">SaaS: Auto Generate Renewal Invoices</field>
            <field name="model_id" ref="ms_saas_manager.model_ms_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_renew()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="cron_mark_overdue" model="ir.cron">
            <field name="name">SaaS: Mark Overdue Invoices</field>
            <field name="model_id" ref="ms_saas_manager.model_ms_invoice"/>
            <field name="state">code</field>
            <field name="code">model._cron_mark_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
