<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_report_financial_pdf" model="ir.actions.report">
        <field name="name">Financial Report</field>
        <field name="model">dynamic.account.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dynamic_accounting_reports.report_financial_template</field>
        <field name="report_file">dynamic_accounting_reports.report_financial_template</field>
        <field name="print_report_name">'Financial Report - %s' % (object.name)</field>
        <field name="binding_type">report</field>
    </record>

    <!-- Report Template -->
    <template id="report_financial_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .report-table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 11px;
                                font-family: Arial, sans-serif;
                            }
                            .report-table th {
                                background-color: #f0f4f7;
                                border: 1px solid #dee2e6;
                                padding: 8px 10px;
                                text-align: left;
                                font-weight: bold;
                                font-size: 10px;
                                text-transform: uppercase;
                            }
                            .report-table td {
                                border-bottom: 1px solid #eee;
                                padding: 5px 10px;
                            }
                            .report-table .text-end {
                                text-align: right;
                            }
                            .level-0 td { font-weight: bold; font-size: 12px; padding-top: 12px; }
                            .level-1 td { font-weight: 600; background-color: #fafafa; }
                            .level-3 td { color: #666; font-size: 10px; }
                            .title-line td {
                                font-weight: bold;
                                font-size: 12px;
                                background-color: #e9ecef;
                                border-top: 2px solid #dee2e6;
                                padding-top: 10px;
                            }
                            .total-line td {
                                font-weight: bold;
                                border-top: 1px solid #adb5bd;
                                background-color: #f8f9fa;
                            }
                            .grand-total td {
                                font-weight: 800;
                                font-size: 12px;
                                border-top: 2px solid #212529;
                                border-bottom: 2px solid #212529;
                                background-color: #e9ecef;
                            }
                            .text-danger { color: #dc3545; }
                        </style>

                        <!-- Report Header -->
                        <div class="text-center mb-4">
                            <h2 t-if="data and data.get('report_data')">
                                <t t-esc="data['report_data'].get('report_name', doc.name)"/>
                            </h2>
                            <h2 t-else="" t-esc="doc.name"/>
                            <p class="text-muted" t-if="data and data.get('report_data')">
                                <t t-esc="data['report_data'].get('company_name', '')"/>
                                <br/>
                                <t t-if="data['report_data'].get('date_from')">
                                    <t t-esc="data['report_data']['date_from']"/>
                                    -
                                </t>
                                <t t-esc="data['report_data'].get('date_to', '')"/>
                            </p>
                        </div>

                        <!-- Report Table -->
                        <table class="report-table" t-if="data and data.get('report_data')">
                            <thead>
                                <tr>
                                    <th style="min-width: 250px;">Name</th>
                                    <t t-foreach="data['report_data'].get('columns', [])" t-as="col">
                                        <th class="text-end" t-esc="col.get('name', '')"/>
                                    </t>
                                    <!-- Fallback for reports with fixed columns -->
                                    <t t-if="not data['report_data'].get('columns')">
                                        <th class="text-end">Amount</th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="data['report_data'].get('lines', [])" t-as="line">
                                    <tr t-att-class="
                                        ('title-line ' if line.get('is_title') else '') +
                                        ('total-line ' if line.get('is_total') and 'o_account_report_grand_total' not in (line.get('class') or '') else '') +
                                        ('grand-total ' if 'o_account_report_grand_total' in (line.get('class') or '') else '') +
                                        ('level-' + str(line.get('level', 2)) + ' ')
                                    ">
                                        <td t-att-style="'padding-left: ' + str((line.get('level', 0) * 15) + 10) + 'px;'">
                                            <t t-esc="line.get('name', '')"/>
                                        </td>
                                        <t t-foreach="line.get('columns', [])" t-as="col">
                                            <td class="text-end"
                                                t-att-class="'text-danger' if (col.get('no_format') or 0) &lt; 0 else ''">
                                                <t t-esc="col.get('name', '')"/>
                                            </td>
                                        </t>
                                        <!-- Fill empty cells for title lines -->
                                        <t t-if="not line.get('columns')">
                                            <t t-foreach="data['report_data'].get('columns', [{'name': ''}])" t-as="col">
                                                <td class="text-end"/>
                                            </t>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Footer note -->
                        <p class="text-muted small mt-4 text-center">
                            Generated on <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

