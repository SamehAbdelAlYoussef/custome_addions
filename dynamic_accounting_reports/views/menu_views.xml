<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================== -->
    <!-- CLIENT ACTIONS (for each report) -->
    <!-- ============================== -->

    <record id="action_balance_sheet" model="ir.actions.client">
        <field name="name">Balance Sheet</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_balance_sheet')}"/>
    </record>

    <record id="action_profit_loss" model="ir.actions.client">
        <field name="name">Profit &amp; Loss</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_profit_loss')}"/>
    </record>

    <record id="action_trial_balance" model="ir.actions.client">
        <field name="name">Trial Balance</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_trial_balance')}"/>
    </record>

    <record id="action_general_ledger" model="ir.actions.client">
        <field name="name">General Ledger</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_general_ledger')}"/>
    </record>

    <record id="action_aged_receivable" model="ir.actions.client">
        <field name="name">Aged Receivable</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_aged_receivable')}"/>
    </record>

    <record id="action_aged_payable" model="ir.actions.client">
        <field name="name">Aged Payable</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_aged_payable')}"/>
    </record>

    <record id="action_partner_ledger" model="ir.actions.client">
        <field name="name">Partner Ledger</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_partner_ledger')}"/>
    </record>

    <record id="action_cash_flow" model="ir.actions.client">
        <field name="name">Cash Flow Statement</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('dynamic_accounting_reports.report_cash_flow')}"/>
    </record>


    <!-- ============================== -->
    <!--        MAIN MENU STRUCTURE      -->
    <!-- ============================== -->

    <!-- Top-level parent: under Accounting > Reporting -->
    <menuitem id="menu_dynamic_reports_root"
              name="Dynamic Reports"
              parent="account.menu_finance_reports"
              sequence="0"/>

    <!-- Sub-menus for each report -->
    <menuitem id="menu_balance_sheet"
              name="Balance Sheet"
              parent="menu_dynamic_reports_root"
              action="action_balance_sheet"
              sequence="10"/>

    <menuitem id="menu_profit_loss"
              name="Profit &amp; Loss"
              parent="menu_dynamic_reports_root"
              action="action_profit_loss"
              sequence="20"/>

    <menuitem id="menu_trial_balance"
              name="Trial Balance"
              parent="menu_dynamic_reports_root"
              action="action_trial_balance"
              sequence="30"/>

    <menuitem id="menu_general_ledger"
              name="General Ledger"
              parent="menu_dynamic_reports_root"
              action="action_general_ledger"
              sequence="40"/>

    <menuitem id="menu_aged_receivable"
              name="Aged Receivable"
              parent="menu_dynamic_reports_root"
              action="action_aged_receivable"
              sequence="50"/>

    <menuitem id="menu_aged_payable"
              name="Aged Payable"
              parent="menu_dynamic_reports_root"
              action="action_aged_payable"
              sequence="60"/>

    <menuitem id="menu_partner_ledger"
              name="Partner Ledger"
              parent="menu_dynamic_reports_root"
              action="action_partner_ledger"
              sequence="70"/>

    <menuitem id="menu_cash_flow"
              name="Cash Flow Statement"
              parent="menu_dynamic_reports_root"
              action="action_cash_flow"
              sequence="80"/>

    <!-- Configuration Menu -->
    <menuitem id="menu_dynamic_reports_config"
              name="Report Configuration"
              parent="menu_dynamic_reports_root"
              action="action_dynamic_account_report_config"
              sequence="100"
              groups="account.group_account_manager"/>


    <!-- Tax Report Action -->
    <record id="action_tax_report" model="ir.actions.client">
        <field name="name">Tax Report</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('tax_report')}"/>
    </record>
    <menuitem id="menu_tax_report"
              name="Tax Report"
              parent="account.menu_finance_reports"
              action="action_tax_report"
              sequence="90"
              groups="account.group_account_user"/>

</odoo>

