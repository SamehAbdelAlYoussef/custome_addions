<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Report List View -->
    <record id="view_dynamic_account_report_list" model="ir.ui.view">
        <field name="name">dynamic.account.report.list</field>
        <field name="model">dynamic.account.report</field>
        <field name="arch" type="xml">
            <list string="Accounting Reports">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="report_type"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Report Form View -->
    <record id="view_dynamic_account_report_form" model="ir.ui.view">
        <field name="name">dynamic.account.report.form</field>
        <field name="model">dynamic.account.report</field>
        <field name="arch" type="xml">
            <form string="Accounting Report">
                <header>
                    <button name="action_open_report" string="View Report" type="object"
                            class="btn-primary" icon="fa-bar-chart"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Report Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="sequence"/>
                            <field name="date_range"/>
                            <field name="use_date_to_only"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group string="Filters">
                            <field name="filter_date_range"/>
                            <field name="filter_comparison"/>
                            <field name="filter_journals"/>
                            <field name="filter_accounts"/>
                            <field name="filter_partners"/>
                            <field name="filter_analytic"/>
                            <field name="filter_unfold_all"/>
                            <field name="filter_hierarchy"/>
                            <field name="filter_multi_company" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Report Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="line_type"/>
                                    <field name="account_type_ids"
                                           invisible="line_type not in ('account_type',)"/>
                                    <field name="code_from"
                                           invisible="line_type != 'account_codes'"/>
                                    <field name="code_to"
                                           invisible="line_type != 'account_codes'"/>
                                    <field name="formula"
                                           invisible="line_type != 'formula'"/>
                                    <field name="parent_id"/>
                                    <field name="level"/>
                                    <field name="sign"/>
                                    <field name="hide_if_zero"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Report Line Form View -->
    <record id="view_dynamic_account_report_line_form" model="ir.ui.view">
        <field name="name">dynamic.account.report.line.form</field>
        <field name="model">dynamic.account.report.line</field>
        <field name="arch" type="xml">
            <form string="Report Line">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="line_type"/>
                            <field name="level"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="account_type_ids"
                                   invisible="line_type not in ('account_type',)"/>
                            <field name="code_from"
                                   invisible="line_type != 'account_codes'"/>
                            <field name="code_to"
                                   invisible="line_type != 'account_codes'"/>
                            <field name="formula"
                                   invisible="line_type != 'formula'"/>
                            <field name="sign"/>
                            <field name="hide_if_zero"/>
                            <field name="is_bold"/>
                            <field name="domain_filter"/>
                        </group>
                    </group>
                    <field name="children_ids">
                        <list>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="line_type"/>
                            <field name="level"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open report configuration -->
    <record id="action_dynamic_account_report_config" model="ir.actions.act_window">
        <field name="name">Report Configuration</field>
        <field name="res_model">dynamic.account.report</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first dynamic accounting report
            </p>
            <p>
                Configure custom accounting reports with flexible line definitions,
                account type groupings, and formulas.
            </p>
        </field>
    </record>

</odoo>

