<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_accounting_reports.MainReport">
        <div class="o_ent_report">

            <!-- LOADING -->
            <div t-if="state.loading" class="o_ent_loading">
                <i class="fa fa-circle-o-notch fa-spin fa-2x"/>
            </div>

            <div t-if="!state.loading and state.reportData" class="o_ent_main">

                <!-- ============================================================ -->
                <!-- TOP CONTROL BAR                                              -->
                <!-- ============================================================ -->
                <div class="o_ent_topbar">
                    <div class="o_ent_topbar_inner">

                        <!-- PDF Button -->
                        <button class="o_ent_btn_pdf" t-on-click="onExportPdf">PDF</button>

                        <!-- XLSX Button -->
                        <button class="o_ent_btn_xlsx" t-on-click="onExportXlsx">XLSX</button>

                        <!-- Report Name + Gear -->
                        <span class="o_ent_report_name">
                            <t t-esc="state.reportName"/>
                            <i class="fa fa-cog o_ent_gear" t-on-click="() => this.toggleDropdown('options')"/>
                        </span>

                        <!-- Options Dropdown (gear) -->
                        <div class="o_ent_dd_anchor" t-if="state.activeDropdown === 'options'">
                            <div class="o_ent_dd_menu">
                                <div class="o_ent_dd_item" t-on-click="toggleAllEntries">
                                    <i t-att-class="state.allEntries ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                    Draft Entries
                                </div>
                                <div class="o_ent_dd_item" t-on-click="toggleUnfoldAll">
                                    <i t-att-class="state.unfoldAll ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                    Unfold All
                                </div>
                            </div>
                        </div>

                        <!-- SEPARATOR -->
                        <span class="o_ent_sep"/>

                        <!-- DATE PILL -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.date_range">
                            <button class="o_ent_pill" t-on-click="() => this.toggleDropdown('date')">
                                <i class="fa fa-calendar"/>
                                <t t-esc="dateLabel"/>
                            </button>
                            <div class="o_ent_dd_menu" t-if="state.activeDropdown === 'date'">
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('this_month')">
                                    <i t-att-class="state.dateRange === 'this_month' ? 'fa fa-check' : 'fa fa-fw'"/> This Month</div>
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('this_quarter')">
                                    <i t-att-class="state.dateRange === 'this_quarter' ? 'fa fa-check' : 'fa fa-fw'"/> This Quarter</div>
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('this_year')">
                                    <i t-att-class="state.dateRange === 'this_year' ? 'fa fa-check' : 'fa fa-fw'"/> This Financial Year</div>
                                <div class="o_ent_dd_hr"/>
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('last_month')">
                                    <i t-att-class="state.dateRange === 'last_month' ? 'fa fa-check' : 'fa fa-fw'"/> Last Month</div>
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('last_quarter')">
                                    <i t-att-class="state.dateRange === 'last_quarter' ? 'fa fa-check' : 'fa fa-fw'"/> Last Quarter</div>
                                <div class="o_ent_dd_item" t-on-click="() => this.setDateRange('last_year')">
                                    <i t-att-class="state.dateRange === 'last_year' ? 'fa fa-check' : 'fa fa-fw'"/> Last Financial Year</div>
                                <div class="o_ent_dd_hr"/>
                                <div class="o_ent_dd_section">
                                    <div class="d-flex gap-2" t-if="!state.filters.use_date_to_only">
                                        <input type="date" class="o_ent_input" t-att-value="state.dateFrom" t-on-change="onChangeDateFrom" placeholder="From"/>
                                        <input type="date" class="o_ent_input" t-att-value="state.dateTo" t-on-change="onChangeDateTo" placeholder="To"/>
                                    </div>
                                    <div t-if="state.filters.use_date_to_only">
                                        <span class="o_ent_dd_label">As of</span>
                                        <input type="date" class="o_ent_input w-100" t-att-value="state.dateTo" t-on-change="onChangeDateTo"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- COMPARISON PILL -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.comparison">
                            <button class="o_ent_pill" t-att-class="state.showComparison ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('comparison')">
                                <i class="fa fa-exchange"/>
                                Comparison
                            </button>
                            <div class="o_ent_dd_menu" t-if="state.activeDropdown === 'comparison'">
                                <div class="o_ent_dd_item" t-on-click="toggleComparison">
                                    <i t-att-class="state.showComparison ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                    Enable
                                </div>
                                <t t-if="state.showComparison">
                                    <div class="o_ent_dd_hr"/>
                                    <div class="o_ent_dd_item" t-on-click="() => this.setComparisonType('previous_period')">
                                        <i t-att-class="state.comparisonType === 'previous_period' ? 'fa fa-check' : 'fa fa-fw'"/> Previous Period</div>
                                    <div class="o_ent_dd_item" t-on-click="() => this.setComparisonType('previous_year')">
                                        <i t-att-class="state.comparisonType === 'previous_year' ? 'fa fa-check' : 'fa fa-fw'"/> Previous Year</div>
                                    <div class="o_ent_dd_section">
                                        <span class="o_ent_dd_label">Periods</span>
                                        <input type="number" class="o_ent_input w-100" min="1" max="4"
                                               t-att-value="state.comparisonNumber" t-on-change="setComparisonNumber"/>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- ═══════════════════════════════════════════ -->
                        <!-- COMPANY / BRANCH PILL (NEW)                -->
                        <!-- ═══════════════════════════════════════════ -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.multi_company and state.companyOptions.length > 1">
                            <button class="o_ent_pill" t-att-class="state.selectedCompanies.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('companies')">
                                <i class="fa fa-building"/>
                                <t t-esc="companyLabel"/>
                                <t t-if="state.selectedCompanies.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedCompanies.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'companies'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search company / branch..."
                                           t-on-input="onCompanySearch"
                                           t-att-value="state.companySearch || ''"/>
                                </div>
                                <t t-if="state.selectedCompanies.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearCompanyFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredCompanies" t-as="c" t-key="c.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.toggleCompany(c.id)">
                                        <i t-att-class="this.isCompanySelected(c.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <t t-esc="c.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredCompanies.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No companies found
                                </div>
                            </div>
                        </div>

                        <!-- ═══════════════════════════════════════════ -->
                        <!-- JOURNALS PILL (with search added)          -->
                        <!-- ═══════════════════════════════════════════ -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.journals and state.journalOptions.length">
                            <button class="o_ent_pill" t-att-class="state.selectedJournals.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('journals')">
                                <i class="fa fa-book"/>
                                Journals
                                <t t-if="state.selectedJournals.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedJournals.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'journals'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search journals..."
                                           t-on-input="onJournalSearch"
                                           t-att-value="state.journalSearch || ''"/>
                                </div>
                                <t t-if="state.selectedJournals.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearJournalFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredJournals" t-as="j" t-key="j.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.toggleJournal(j.id)">
                                        <i t-att-class="this.isJournalSelected(j.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <span class="o_ent_jcode" t-esc="j.code"/>
                                        <t t-esc="j.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredJournals.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No journals found
                                </div>
                            </div>
                        </div>

                        <!-- ═══════════════════════════════════════════ -->
                        <!-- ACCOUNTS PILL (with search added)          -->
                        <!-- ═══════════════════════════════════════════ -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.accounts and state.accountOptions.length">
                            <button class="o_ent_pill" t-att-class="state.selectedAccounts.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('accounts')">
                                <i class="fa fa-bookmark"/>
                                Accounts
                                <t t-if="state.selectedAccounts.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedAccounts.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'accounts'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search accounts..."
                                           t-on-input="onAccountSearch"
                                           t-att-value="state.accountSearch || ''"/>
                                </div>
                                <t t-if="state.selectedAccounts.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearAccountFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredAccounts" t-as="a" t-key="a.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.toggleAccount(a.id)">
                                        <i t-att-class="this.isAccountSelected(a.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <t t-esc="a.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredAccounts.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No accounts found
                                </div>
                            </div>
                        </div>


                        <!-- ═══════════════════════════════════════════ -->
                        <!-- ACCOUNT TYPE PILL (Receivable / Payable)   -->
                        <!-- ═══════════════════════════════════════════ -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.account_type"
                             style="display:flex; align-items:center; gap:6px;">
                            <span style="font-size:13px; font-weight:500; color:#495057;">
                                <i class="fa fa-filter" style="margin-right:4px;"/>Account Type:
                            </span>
                            <select t-on-change="onAccountTypeChange"
                                    style="padding:4px 10px; border:1px solid #dee2e6; border-radius:6px; font-size:13px; background:#fff; cursor:pointer; min-width:170px;">
                                <option value="all" t-att-selected="state.selectedAccountType === 'all' ? 'selected' : undefined">Receivable &amp; Payable</option>
                                <option value="receivable" t-att-selected="state.selectedAccountType === 'receivable' ? 'selected' : undefined">Receivable</option>
                                <option value="payable" t-att-selected="state.selectedAccountType === 'payable' ? 'selected' : undefined">Payable</option>
                            </select>
                        </div>

                        <!-- ═══════════════════════════════════════════ -->
                        <!-- PARTNERS PILL (search already existed)     -->
                        <!-- ═══════════════════════════════════════════ -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.partners and state.partnerOptions.length">
                            <button class="o_ent_pill" t-att-class="state.selectedPartners.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('partners')">
                                <i class="fa fa-users"/>
                                Partners
                                <t t-if="state.selectedPartners.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedPartners.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'partners'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search partners..."
                                           t-on-input="onPartnerSearch"
                                           t-att-value="state.partnerSearch || ''"/>
                                </div>
                                <t t-if="state.selectedPartners.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearPartnerFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredPartners" t-as="p" t-key="p.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.togglePartner(p.id)">
                                        <i t-att-class="this.isPartnerSelected(p.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <t t-esc="p.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredPartners.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No partners found
                                </div>
                            </div>
                        </div>

                        <!-- ANALYTIC ACCOUNTS PILL -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.analytic and state.analyticAccountOptions.length">
                            <button class="o_ent_pill" t-att-class="state.selectedAnalyticAccounts.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('analyticAccounts')">
                                <i class="fa fa-sitemap"/>
                                Analytic Accounts
                                <t t-if="state.selectedAnalyticAccounts.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedAnalyticAccounts.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'analyticAccounts'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search analytic accounts..."
                                           t-on-input="onAnalyticAccountSearch"
                                           t-att-value="state.analyticAccountSearch || ''"/>
                                </div>
                                <t t-if="state.selectedAnalyticAccounts.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearAnalyticAccountFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredAnalyticAccounts" t-as="aa" t-key="aa.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.toggleAnalyticAccount(aa.id)">
                                        <i t-att-class="this.isAnalyticAccountSelected(aa.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <t t-esc="aa.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredAnalyticAccounts.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No analytic accounts found
                                </div>
                            </div>
                        </div>

                        <!-- ANALYTIC PLANS PILL -->
                        <div class="o_ent_pill_wrap" t-if="state.filters.analytic and state.analyticPlanOptions.length">
                            <button class="o_ent_pill" t-att-class="state.selectedAnalyticPlans.length ? 'active' : ''"
                                    t-on-click="() => this.toggleDropdown('analyticPlans')">
                                <i class="fa fa-folder-open"/>
                                Analytic Plans
                                <t t-if="state.selectedAnalyticPlans.length">
                                    <span class="o_ent_badge"><t t-esc="state.selectedAnalyticPlans.length"/></span>
                                </t>
                            </button>
                            <div class="o_ent_dd_menu o_ent_dd_scroll" t-if="state.activeDropdown === 'analyticPlans'">
                                <div class="o_ent_dd_search">
                                    <input type="text" placeholder="Search analytic plans..."
                                           t-on-input="onAnalyticPlanSearch"
                                           t-att-value="state.analyticPlanSearch || ''"/>
                                </div>
                                <t t-if="state.selectedAnalyticPlans.length">
                                    <div class="o_ent_dd_clear" t-on-click="clearAnalyticPlanFilter">
                                        <i class="fa fa-times"/> Clear selection
                                    </div>
                                </t>
                                <t t-foreach="filteredAnalyticPlans" t-as="ap" t-key="ap.id">
                                    <div class="o_ent_dd_item" t-on-click="() => this.toggleAnalyticPlan(ap.id)">
                                        <i t-att-class="this.isAnalyticPlanSelected(ap.id) ? 'fa fa-check-square-o' : 'fa fa-square-o'"/>
                                        <t t-esc="ap.name"/>
                                    </div>
                                </t>
                                <div t-if="filteredAnalyticPlans.length === 0" class="o_ent_dd_item" style="color:#adb5bd;font-style:italic;">
                                    No analytic plans found
                                </div>
                            </div>
                        </div>

                        <!-- POSTED ENTRIES PILL -->
                        <button class="o_ent_pill" t-att-class="state.allEntries ? '' : 'active'" t-on-click="toggleAllEntries">
                            <i class="fa fa-filter"/>
                            <t t-if="state.allEntries">All Entries</t>
                            <t t-else="">Posted Entries</t>
                        </button>

                    </div>
                </div>

                <!-- WARNING BANNER (if draft entries) -->
                <div class="o_ent_banner" t-if="state.allEntries">
                    <i class="fa fa-info-circle"/>
                    There are <strong>unposted Journal Entries</strong> prior or included in this period.
                </div>

                <!-- ============================================================ -->
                <!-- REPORT TABLE                                                 -->
                <!-- ============================================================ -->
                <div class="o_ent_content">
                    <div class="o_ent_table_wrap">
                        <table class="o_ent_table">
                            <thead>
                                <!-- Period header row -->
                                <tr class="o_ent_period_row">
                                    <th/>
                                    <th t-att-colspan="displayColumns.length" class="o_ent_period_header">
                                        <t t-esc="dateLabel"/>
                                    </th>
                                </tr>
                                <!-- Column headers -->
                                <tr>
                                    <th class="o_ent_th_name"/>
                                    <t t-foreach="displayColumns" t-as="col" t-key="col_index">
                                        <th class="o_ent_th_num">
                                            <span class="o_ent_sort_icon">↕</span>
                                            <t t-esc="col.name"/>
                                        </th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="filteredLines" t-as="line" t-key="line.id">
                                    <tr t-if="isLineVisible(line)" t-att-class="getLineClasses(line)">
                                        <!-- Name Cell -->
                                        <td class="o_ent_td_name"
                                            t-att-style="'padding-left: ' + ((line.level || 0) * 24 + 16) + 'px;'">

                                            <span t-if="line.unfoldable" class="o_ent_caret"
                                                  t-on-click="() => this.onToggleLine(line.id)">
                                                <i t-att-class="state.unfoldedLines.has(line.id) ? 'fa fa-caret-down' : 'fa fa-caret-right'"/>
                                            </span>

                                            <span t-if="line.move_id" class="o_ent_link"
                                                  t-on-click="() => this.onClickMoveLine(line.move_id)">
                                                <t t-if="line.date"><span class="o_ent_muted" t-esc="line.date"/> </t>
                                                <t t-esc="line.name"/>
                                                <t t-if="line.partner_name"> — <span class="o_ent_muted" t-esc="line.partner_name"/></t>
                                                <t t-if="line.ref"> — <span class="o_ent_muted" t-esc="line.ref"/></t>
                                            </span>
                                            <span t-else="" t-esc="line.name"/>
                                        </td>

                                        <!-- Value Cells -->
                                        <t t-foreach="line.columns || []" t-as="col" t-key="col_index">
                                            <td class="o_ent_td_num"
                                                t-att-class="(col.no_format or 0) &lt; 0 ? 'o_ent_red' : ((col.no_format or 0) === 0 ? 'o_ent_zero' : '')">
                                                <t t-esc="col.name || '0.00'"/>
                                            </td>
                                        </t>

                                        <!-- Empty cells for titles -->
                                        <t t-if="!line.columns or !line.columns.length">
                                            <t t-foreach="displayColumns" t-as="c" t-key="c_index">
                                                <td class="o_ent_td_num"/>
                                            </t>
                                        </t>
                                    </tr>
                                </t>

                                <!-- Empty State -->
                                <tr t-if="!filteredLines.length">
                                    <td t-att-colspan="displayColumns.length + 1" class="o_ent_empty">
                                        <i class="fa fa-bar-chart"/> No data available for the selected period.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- No Report -->
            <div t-if="!state.loading and !state.reportData" class="o_ent_empty">
                <i class="fa fa-bar-chart fa-3x d-block mb-3" style="opacity:0.2;"/>
                Select a report from the menu.
            </div>
        </div>
    </t>

</templates>
