<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="report_petty_cash" model="dynamic.account.report">
        <field name="name">Petty Cash Report</field>
        <field name="report_type">petty_cash</field>
        <field name="sequence">77</field>
        <field name="filter_date_range">True</field>
        <field name="filter_comparison">False</field>
        <field name="filter_journals">True</field>
        <field name="filter_partners">True</field>
        <field name="filter_unfold_all">True</field>
    </record>

    <record id="action_petty_cash_report" model="ir.actions.client">
        <field name="name">Petty Cash Report</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('report_petty_cash')}"/>
    </record>

    <menuitem id="menu_petty_cash_report"
              name="Petty Cash Report"
              parent="menu_dynamic_reports_root"
              action="action_petty_cash_report"
              sequence="77"/>
</odoo>
