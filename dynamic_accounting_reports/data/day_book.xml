<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="report_day_book" model="dynamic.account.report">
        <field name="name">Day Book</field>
        <field name="report_type">day_book</field>
        <field name="sequence">79</field>
        <field name="filter_date_range">True</field>
        <field name="filter_comparison">False</field>
        <field name="filter_journals">True</field>
        <field name="filter_partners">True</field>
        <field name="filter_unfold_all">True</field>
    </record>

    <record id="action_day_book_report" model="ir.actions.client">
        <field name="name">Day Book</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('report_day_book')}"/>
    </record>

    <menuitem id="menu_day_book_report"
              name="Day Book"
              parent="menu_dynamic_reports_root"
              action="action_day_book_report"
              sequence="79"/>
</odoo>
