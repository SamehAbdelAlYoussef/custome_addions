<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="report_budget_vs_actual" model="dynamic.account.report">
        <field name="name">Budget vs Actual</field>
        <field name="report_type">budget_vs_actual</field>
        <field name="sequence">80</field>
        <field name="filter_date_range">True</field>
        <field name="filter_comparison">False</field>
        <field name="filter_journals">True</field>
        <field name="filter_partners">True</field>
        <field name="filter_unfold_all">True</field>
    </record>

    <record id="action_budget_vs_actual_report" model="ir.actions.client">
        <field name="name">Budget vs Actual</field>
        <field name="tag">dynamic_account_report</field>
        <field name="context" eval="{'report_id': ref('report_budget_vs_actual')}"/>
    </record>

    <menuitem id="menu_budget_vs_actual_report"
              name="Budget vs Actual"
              parent="menu_dynamic_reports_root"
              action="action_budget_vs_actual_report"
              sequence="80"/>
</odoo>
